// Google Apps Script 코드 (v2)
function doGet(e) {
  try {
    var ss = SpreadsheetApp.openById(e.parameter.spreadsheetId);
    var sheet = ss.getSheetByName('Data') || ss.insertSheet('Data');
    if (e.parameter.action === 'load') {
      var v = sheet.getRange('A1').getValue();
      return res({result:'success', data: v ? JSON.parse(v) : {}});
    }
    return res({result:'error', message:'Invalid action'});
  } catch(err) { return res({result:'error', message:err.toString()}); }
}
function doPost(e) {
  try {
    var p = JSON.parse(e.postData.contents);
    var ss = SpreadsheetApp.openById(p.spreadsheetId);
    var sheet = ss.getSheetByName('Data') || ss.insertSheet('Data');
    if (p.action === 'save') {
      sheet.clearContents();
      sheet.getRange('A1').setValue(JSON.stringify(p.data));
      return res({result:'success'});
    }
    return res({result:'error', message:'Invalid action'});
  } catch(err) { return res({result:'error', message:err.toString()}); }
}
function res(obj) {
  return ContentService.createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}</pre>
