<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>지민쀼 가계부</title>
    <style>
        :root {
            --primary: #4f46e5;
            --primary-dark: #3730a3;
            --primary-light: #eef2ff;
            --income-color: #16a34a;
            --income-bg: #f0fdf4;
            --expense-color: #dc2626;
            --expense-bg: #fef2f2;
            --balance-color: #1d4ed8;
            --balance-bg: #eff6ff;
            --savings-color: #d97706;
            --savings-bg: #fffbeb;
            --husband-color: #1d4ed8;
            --husband-bg: #eff6ff;
            --wife-color: #be185d;
            --wife-bg: #fdf2f8;
            --joint-color: #4f46e5;
            --joint-bg: #eef2ff;
            --bg: #f1f5f9;
            --card: #ffffff;
            --border: #e2e8f0;
            --border-light: #f1f5f9;
            --text: #0f172a;
            --text-2: #475569;
            --text-3: #94a3b8;
            --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 2px 8px rgba(0,0,0,0.04);
            --r: 12px; --r-sm: 8px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family: -apple-system,BlinkMacSystemFont,'Segoe UI','Malgun Gothic',sans-serif; background:var(--bg); min-height:100vh; color:var(--text); font-size:14px; line-height:1.5; }

        /* TOPBAR */
        .topbar { position:sticky; top:0; z-index:100; height:56px; background:#fff; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; padding:0 20px; box-shadow:0 1px 4px rgba(0,0,0,0.06); }
        .topbar-title { font-size:15px; font-weight:700; display:flex; align-items:center; gap:6px; cursor:pointer; color:var(--text); }
        .topbar-title:hover { opacity:.7; }
        .edit-icon { font-size:11px; color:var(--text-3); }
        .month-nav { display:flex; align-items:center; gap:6px; }
        .nav-arrow { width:28px; height:28px; border:1px solid var(--border); border-radius:6px; background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:11px; color:var(--text-2); transition:all .15s; }
        .nav-arrow:hover { background:var(--primary); color:#fff; border-color:var(--primary); }
        .nav-sep { width:1px; height:18px; background:var(--border); margin:0 2px; }
        .month-nav select { border:1px solid var(--border); border-radius:6px; padding:5px 8px; font-size:13px; background:#fff; cursor:pointer; color:var(--text); }
        .month-nav select:focus { outline:none; border-color:var(--primary); }

        /* PAGE */
        .page { max-width:1400px; margin:0 auto; padding:20px 16px; }

        /* CARD */
        .card { background:var(--card); border-radius:var(--r); border:1px solid var(--border); box-shadow:var(--shadow); padding:20px; margin-bottom:16px; }
        .card-hd { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; padding-bottom:12px; border-bottom:1px solid var(--border-light); }
        .card-title { font-size:14px; font-weight:600; display:flex; align-items:center; gap:7px; color:var(--text); }
        .card-icon { font-size:16px; }

        /* Section accent */
        .income-card { border-left:3px solid var(--income-color); }
        .fixed-card  { border-left:3px solid var(--balance-color); }
        .loan-card   { border-left:3px solid #ea580c; }
        .allow-card  { border-left:3px solid #9333ea; }
        .var-card    { border-left:3px solid var(--expense-color); }
        .sav-card    { border-left:3px solid var(--savings-color); }
        .income-card .card-title { color:var(--income-color); }
        .fixed-card .card-title  { color:var(--balance-color); }
        .loan-card .card-title   { color:#ea580c; }
        .allow-card .card-title  { color:#9333ea; }
        .var-card .card-title    { color:var(--expense-color); }
        .sav-card .card-title    { color:var(--savings-color); }

        /* SUMMARY BAR */
        .summary-bar { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:12px; }
        .sum-chip { background:var(--card); border-radius:var(--r); border:1px solid var(--border); box-shadow:var(--shadow); padding:14px 16px; }
        .sum-chip label { display:block; font-size:11px; font-weight:500; color:var(--text-3); margin-bottom:4px; }
        .sum-chip .val  { font-size:18px; font-weight:700; }
        .sum-chip.income .val  { color:var(--income-color); }
        .sum-chip.expense .val { color:var(--expense-color); }
        .sum-chip.balance .val { color:var(--balance-color); }
        .sum-chip.savings .val { color:var(--savings-color); }
        .exp-chips { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; }
        .exp-chip { padding:10px 12px; background:var(--expense-bg); border-radius:var(--r-sm); text-align:center; border:1px solid #fecaca; }
        .exp-chip label { display:block; font-size:11px; color:var(--text-2); margin-bottom:2px; }
        .exp-chip .val  { font-size:13px; font-weight:700; color:var(--expense-color); }

        /* PERSON SUMMARY */
        .person-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:16px; }
        .person-card { background:var(--card); border-radius:var(--r); border:1px solid var(--border); box-shadow:var(--shadow); padding:18px; position:relative; overflow:hidden; }
        .person-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
        .person-card.husband::before { background:var(--husband-color); }
        .person-card.wife::before    { background:var(--wife-color); }
        .person-card.family::before  { background:var(--primary); }
        .person-card-lbl { font-size:11px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; margin-bottom:12px; }
        .person-card.husband .person-card-lbl { color:var(--husband-color); }
        .person-card.wife .person-card-lbl    { color:var(--wife-color); }
        .person-card.family .person-card-lbl  { color:var(--primary); }
        .pstat { display:flex; justify-content:space-between; align-items:baseline; padding:5px 0; border-bottom:1px solid var(--border-light); font-size:13px; }
        .pstat:last-child { border-bottom:none; }
        .pstat-lbl { color:var(--text-2); }
        .pstat-val { font-weight:600; }
        .pstat-val.i { color:var(--income-color); }
        .pstat-val.e { color:var(--expense-color); }
        .pstat-val.b { color:var(--balance-color); }
        .pstat-val.s { color:var(--savings-color); }

        /* DONUT CHART */
        .analysis-inner { display:flex; gap:24px; align-items:center; flex-wrap:wrap; }
        .donut-wrap { flex-shrink:0; position:relative; }
        .donut-legend { flex:1; min-width:180px; }
        .legend-row { display:flex; align-items:center; gap:8px; padding:5px 0; border-bottom:1px solid var(--border-light); font-size:13px; }
        .legend-row:last-child { border-bottom:none; }
        .legend-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
        .legend-lbl { flex:1; color:var(--text-2); }
        .legend-pct { font-weight:600; color:var(--text); min-width:38px; text-align:right; }
        .legend-val { color:var(--text-3); min-width:80px; text-align:right; }

        /* BUDGET CARD */
        .budget-toggle-btn { font-size:12px; color:var(--text-3); background:none; border:none; cursor:pointer; padding:4px 8px; border-radius:6px; transition:background .15s; }
        .budget-toggle-btn:hover { background:var(--border-light); color:var(--text-2); }
        .budget-inputs { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:12px; }
        .budget-input-row label { display:block; font-size:12px; font-weight:500; color:var(--text-2); margin-bottom:4px; }
        .budget-input-row input { width:100%; padding:8px 10px; border:1.5px solid var(--border); border-radius:var(--r-sm); font-size:13px; text-align:right; color:var(--text); background:#fff; }
        .budget-input-row input:focus { outline:none; border-color:var(--primary); }
        .budget-bar-wrap { margin-top:10px; padding:8px 10px; background:var(--border-light); border-radius:var(--r-sm); }
        .budget-bar-top { display:flex; justify-content:space-between; font-size:11px; margin-bottom:5px; }
        .budget-bar-lbl { font-weight:500; }

        /* SECTIONS GRID */
        .sections-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(360px,1fr)); gap:16px; margin-bottom:16px; }

        /* FORM */
        .form-row { margin-bottom:10px; }
        .form-row > label { display:block; font-size:12px; font-weight:500; color:var(--text-2); margin-bottom:4px; }
        .form-row select, .form-row input[type="text"] { width:100%; padding:9px 11px; border:1.5px solid var(--border); border-radius:var(--r-sm); font-size:14px; color:var(--text); background:#fff; transition:border-color .15s,box-shadow .15s; }
        .form-row input[type="text"] { text-align:right; }
        .form-row select:focus, .form-row input:focus { outline:none; border-color:var(--primary); box-shadow:0 0 0 3px rgba(79,70,229,.1); }
        .custom-inp { display:none; margin-top:6px; }
        .custom-inp.show { display:block; }

        /* PERSON SELECTOR */
        .pselector { display:flex; gap:5px; margin-bottom:12px; }
        .pbtn { flex:1; padding:7px 6px; border:1.5px solid var(--border); border-radius:var(--r-sm); background:#fff; cursor:pointer; font-size:12px; font-weight:500; color:var(--text-2); transition:all .15s; text-align:center; }
        .pbtn:hover { border-color:var(--primary); color:var(--primary); }
        .pbtn.ah { background:var(--husband-bg); border-color:var(--husband-color); color:var(--husband-color); }
        .pbtn.aw { background:var(--wife-bg); border-color:var(--wife-color); color:var(--wife-color); }
        .pbtn.aj { background:var(--joint-bg); border-color:var(--joint-color); color:var(--joint-color); }

        /* ADD BUTTONS ROW */
        .add-row { display:flex; gap:6px; margin-bottom:8px; }
        .add-row .btn-primary { flex:1; }

        /* FAVORITES */
        .fav-row { display:flex; flex-wrap:wrap; gap:5px; margin-bottom:10px; min-height:0; }
        .fav-chip { padding:4px 9px; border:1.5px solid #fde68a; border-radius:20px; background:#fffbeb; cursor:pointer; font-size:11px; color:#92400e; transition:all .15s; display:flex; align-items:center; gap:4px; }
        .fav-chip:hover { background:#fef3c7; border-color:#f59e0b; }
        .fav-chip span { color:var(--text-3); }
        .fav-clear { padding:3px 7px; border:1px solid var(--border); border-radius:20px; background:#fff; cursor:pointer; font-size:10px; color:var(--text-3); }
        .fav-clear:hover { background:var(--expense-bg); color:var(--expense-color); border-color:#fecaca; }
        .fav-label { font-size:10px; color:var(--text-3); align-self:center; }

        /* BUTTONS */
        .btn { display:inline-flex; align-items:center; justify-content:center; gap:5px; padding:9px 14px; border:none; border-radius:var(--r-sm); font-size:13px; font-weight:500; cursor:pointer; transition:all .15s; white-space:nowrap; }
        .btn-primary { background:var(--primary); color:#fff; width:100%; }
        .btn-primary:hover { background:var(--primary-dark); box-shadow:0 4px 12px rgba(79,70,229,.3); }
        .btn-sm { padding:4px 9px; font-size:12px; border-radius:6px; }
        .btn-edit { background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
        .btn-edit:hover { background:#dcfce7; }
        .btn-del  { background:#fef2f2; color:#b91c1c; border:1px solid #fecaca; }
        .btn-del:hover  { background:#fee2e2; }
        .btn-sec  { background:#f8fafc; color:var(--text-2); border:1px solid var(--border); }
        .btn-sec:hover { background:var(--border); }
        .btn-star { padding:9px 12px; background:#fffbeb; border:1.5px solid #fde68a; border-radius:var(--r-sm); cursor:pointer; font-size:14px; transition:all .15s; flex-shrink:0; }
        .btn-star:hover { background:#fef3c7; border-color:#f59e0b; }

        /* ACTION ROW */
        .action-row { display:flex; gap:10px; margin-bottom:16px; }
        .act-btn { flex:1; padding:10px 14px; border:1.5px solid var(--border); border-radius:var(--r-sm); background:#fff; font-size:13px; font-weight:500; color:var(--text-2); cursor:pointer; transition:all .15s; }
        .act-btn:hover { border-color:var(--primary); color:var(--primary); background:var(--primary-light); }
        .act-btn.primary { background:var(--primary); color:#fff; border-color:var(--primary); }
        .act-btn.primary:hover { background:var(--primary-dark); border-color:var(--primary-dark); color:#fff; }

        /* ITEM LIST */
        .item-list { margin-top:14px; max-height:260px; overflow-y:auto; }
        .item-list::-webkit-scrollbar { width:4px; }
        .item-list::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }
        .item { display:flex; align-items:center; gap:8px; padding:9px 11px; border-radius:var(--r-sm); border:1px solid var(--border); margin-bottom:6px; background:#fff; transition:box-shadow .15s; }
        .item:hover { box-shadow:0 2px 8px rgba(0,0,0,.07); }
        .pdot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
        .item-info { flex:1; min-width:0; }
        .item-name { font-size:13px; font-weight:500; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .item-plbl { font-size:11px; color:var(--text-3); }
        .item-amt  { font-size:13px; font-weight:600; color:var(--text); flex-shrink:0; }
        .item-actions { display:flex; gap:4px; flex-shrink:0; }
        .total-row { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:var(--border-light); border-radius:var(--r-sm); border:1px solid var(--border); margin-top:10px; font-size:13px; font-weight:600; }

        /* BUDGET PROGRESS BAR (in section cards) */
        .sec-budget { margin-top:8px; padding:8px 12px; background:var(--border-light); border-radius:var(--r-sm); border:1px solid var(--border); }
        .sec-budget-top { display:flex; justify-content:space-between; font-size:11px; margin-bottom:5px; }
        .sec-budget-lbl { font-weight:500; }

        /* PROGRESS BAR */
        .pbar { height:7px; background:var(--border); border-radius:4px; overflow:hidden; }
        .pbar-fill { height:100%; border-radius:4px; transition:width .4s ease; }

        /* ALLOWANCE */
        .allow-tabs { display:flex; border-bottom:2px solid var(--border); margin-bottom:14px; }
        .allow-tab { flex:1; padding:9px; border:none; background:none; font-size:13px; font-weight:500; color:var(--text-3); cursor:pointer; transition:all .15s; border-bottom:2px solid transparent; margin-bottom:-2px; }
        .allow-tab.ah { color:var(--husband-color); border-bottom-color:var(--husband-color); }
        .allow-tab.aw { color:var(--wife-color); border-bottom-color:var(--wife-color); }
        .allow-disp { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; border-radius:var(--r-sm); border:1px solid var(--border); margin-top:12px; }
        .allow-name { font-size:13px; font-weight:500; }
        .allow-amt  { font-size:15px; font-weight:700; color:var(--expense-color); }

        /* SAVINGS */
        .sav-list { margin-top:14px; max-height:260px; overflow-y:auto; }
        .sav-list::-webkit-scrollbar { width:4px; }
        .sav-list::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }
        .sav-item { display:flex; align-items:center; gap:8px; padding:9px 11px; border-radius:var(--r-sm); border:1px solid var(--border); margin-bottom:6px; background:#fff; }
        .sav-total { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:var(--savings-bg); border-radius:var(--r-sm); border:1px solid #fde68a; margin-top:10px; font-size:13px; font-weight:600; }
        .sav-total .val { color:var(--savings-color); }
        .progress-box { margin-top:12px; padding:12px 14px; background:var(--border-light); border-radius:var(--r-sm); border:1px solid var(--border); }
        .progress-lbl { font-size:12px; color:var(--text-2); margin-bottom:7px; }
        .pbar-txt { font-size:11px; color:var(--text-3); text-align:center; margin-top:6px; }

        /* HISTORY */
        .history-card { background:var(--card); border-radius:var(--r); border:1px solid var(--border); box-shadow:var(--shadow); padding:20px; margin-bottom:16px; }
        .history-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(120px,1fr)); gap:8px; margin-top:14px; }
        .hist-item { padding:11px 10px; border-radius:var(--r-sm); border:1px solid var(--border); background:#fff; text-align:center; cursor:pointer; transition:all .15s; }
        .hist-item:hover { border-color:var(--primary); box-shadow:0 2px 8px rgba(79,70,229,.12); }
        .hist-item.active { background:var(--primary-light); border-color:var(--primary); }
        .hist-month { font-size:11px; color:var(--text-3); margin-bottom:3px; }
        .hist-item.active .hist-month { color:var(--primary); }
        .hist-bal { font-size:13px; font-weight:700; }

        /* YEAR SUMMARY */
        .year-card { background:var(--card); border-radius:var(--r); border:1px solid var(--border); box-shadow:var(--shadow); padding:20px; margin-bottom:16px; }
        .year-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:12px; }
        .yr-chip { padding:12px 14px; border-radius:var(--r-sm); text-align:center; }
        .yr-chip.income { background:var(--income-bg); } .yr-chip.expense { background:var(--expense-bg); }
        .yr-chip.balance { background:var(--balance-bg); } .yr-chip.savings { background:var(--savings-bg); }
        .yr-chip label { display:block; font-size:11px; color:var(--text-2); margin-bottom:3px; }
        .yr-chip .val { font-size:14px; font-weight:700; }
        .yr-chip.income .val { color:var(--income-color); } .yr-chip.expense .val { color:var(--expense-color); }
        .yr-chip.balance .val { color:var(--balance-color); } .yr-chip.savings .val { color:var(--savings-color); }
        .yr-exp-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:18px; }
        .yr-exp-chip { padding:9px 10px; background:var(--expense-bg); border-radius:var(--r-sm); text-align:center; }
        .yr-exp-chip label { display:block; font-size:11px; color:var(--text-2); margin-bottom:2px; }
        .yr-exp-chip .val { font-size:13px; font-weight:600; color:var(--expense-color); }
        .mo-table { width:100%; border-collapse:collapse; font-size:13px; }
        .mo-table th,.mo-table td { padding:9px 10px; text-align:center; border-bottom:1px solid var(--border); }
        .mo-table th { font-size:11px; font-weight:600; letter-spacing:.04em; text-transform:uppercase; color:var(--text-3); background:var(--border-light); }
        .mo-table tr:hover td { background:var(--border-light); }
        .pos { color:var(--income-color); } .neg { color:var(--expense-color); }

        /* CLOUD */
        .cloud-card { background:var(--card); border-radius:var(--r); border:1px solid var(--border); box-shadow:var(--shadow); padding:20px; margin-bottom:16px; }
        .sync-bar { display:flex; align-items:center; gap:8px; padding:10px 12px; background:var(--border-light); border-radius:var(--r-sm); border:1px solid var(--border); margin-bottom:12px; font-size:13px; color:var(--text-2); }
        .sdot { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
        .sdot.connected { background:#22c55e; } .sdot.disconnected { background:#ef4444; }
        .sdot.syncing { background:#f97316; animation:pulse 1s infinite; }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
        .sync-btns { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:8px; }
        .sync-btns .btn { flex:1; min-width:90px; }

        /* SECTION LABEL */
        .sec-label { font-size:11px; font-weight:600; letter-spacing:.06em; text-transform:uppercase; color:var(--text-3); margin-bottom:10px; margin-top:4px; }

        /* MODAL */
        .modal { display:none; position:fixed; inset:0; background:rgba(15,23,42,.5); z-index:300; align-items:center; justify-content:center; backdrop-filter:blur(3px); }
        .modal.open { display:flex; }
        .modal-box { background:#fff; border-radius:var(--r); padding:26px; max-width:560px; width:92%; max-height:88vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,.2); }
        .modal-box h3 { font-size:16px; font-weight:700; margin-bottom:10px; }
        .modal-inp { width:100%; padding:9px 11px; border:1.5px solid var(--border); border-radius:var(--r-sm); font-size:14px; margin-bottom:8px; color:var(--text); }
        .modal-inp:focus { outline:none; border-color:var(--primary); box-shadow:0 0 0 3px rgba(79,70,229,.1); }
        .modal-actions { display:flex; gap:8px; margin-top:16px; }
        .modal-actions .btn { flex:1; }

        /* RESPONSIVE */
        @media (max-width:900px) {
            .summary-bar { grid-template-columns:repeat(2,1fr); }
            .exp-chips { grid-template-columns:repeat(2,1fr); }
            .person-grid { grid-template-columns:1fr; }
            .year-grid { grid-template-columns:repeat(2,1fr); }
            .yr-exp-grid { grid-template-columns:repeat(2,1fr); }
            .analysis-inner { flex-direction:column; align-items:flex-start; }
        }
        @media (max-width:600px) {
            .topbar { padding:0 12px; }
            .page { padding:12px 10px; }
            .sections-grid { grid-template-columns:1fr; }
            .summary-bar { grid-template-columns:repeat(2,1fr); }
            .action-row { flex-direction:column; }
            .sync-btns { flex-direction:column; }
            .budget-inputs { grid-template-columns:1fr; }
            .mo-table { font-size:12px; }
            .mo-table th,.mo-table td { padding:6px 5px; }
        }
    </style>
</head>
<body>

<header class="topbar">
    <div class="topbar-title" onclick="showTitleModal()">
        <span id="budgetTitle">💑 지민쀼 가계부</span>
