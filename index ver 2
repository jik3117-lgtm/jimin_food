<script>
    function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }

    let data = { months:{}, currentMonth:curMonthKey(), title:'💑 지민쀼 가계부', budgets:{}, favorites:{} };
    let cloud = { spreadsheetId:'', scriptUrl:'' };

    const selPerson = { income:'husband', fixed:'joint', loan:'joint', variable:'joint', savings:'joint' };
    const customOn  = { income:false, fixed:false, loan:false, variable:false, savings:false };
    const PLBL = { husband:'남편', wife:'아내', joint:'공동' };
    const PDOT = { husband:'#1d4ed8', wife:'#be185d', joint:'#4f46e5' };

    const IDS = {
        income:   { sel:'incomeSelect',   name:'incomeName',   amt:'incomeAmt',   list:'incomeList',   total:'incomeTotal' },
        fixed:    { sel:'fixedSelect',    name:'fixedName',    amt:'fixedAmt',    list:'fixedList',    total:'fixedTotal' },
        loan:     { sel:'loanSelect',     name:'loanName',     amt:'loanAmt',     list:'loanList',     total:'loanTotal' },
        variable: { sel:'variableSelect', name:'variableName', amt:'variableAmt', list:'variableList', total:'variableTotal' },
        savings:  { sel:'savingsSelect',  name:'savingsName',  amt:'savingsAmt' }
    };

    function curMonthKey(){ const n=new Date(); return `${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,'0')}`; }
    function emptyMonth(){ return {income:[],fixed:[],loan:[],variable:[],savings:[],husbandAllowance:0,wifeAllowance:0}; }
    function isEmptyMonth(d){ if(!d)return true; for(const k of['income','fixed','loan','variable','savings'])if(d[k]?.length)return false; return !d.husbandAllowance&&!d.wifeAllowance; }

    function loadData(){
        const s=localStorage.getItem('familyBudget');
        if(s){ data=JSON.parse(s); Object.keys(data.months).forEach(k=>{if(isEmptyMonth(data.months[k]))delete data.months[k];}); }
        if(!data.months)data.months={};
        if(!data.months[data.currentMonth])data.months[data.currentMonth]=emptyMonth();
        if(!data.title)data.title='💑 지민쀼 가계부';
        if(!data.budgets)data.budgets={};
        if(!data.favorites)data.favorites={};
        const c=localStorage.getItem('familyBudgetCloudConfig');
        if(c)cloud=JSON.parse(c);
        const el1=document.getElementById('cfgSheetId'); const el2=document.getElementById('cfgScriptUrl');
        if(el1)el1.value=cloud.spreadsheetId||''; if(el2)el2.value=cloud.scriptUrl||'';
        if(cloud.spreadsheetId&&cloud.scriptUrl)setSyncStatus('connected','클라우드 연결됨');
    }

    function saveData(){
        Object.keys(data.months).forEach(k=>{if(isEmptyMonth(data.months[k]))delete data.months[k];});
        localStorage.setItem('familyBudget',JSON.stringify(data));
    }

    function W(n){ return '₩'+Number(n).toLocaleString(); }
    function fmtInput(el){ const v=el.value.replace(/[^0-9-]/g,''); if(!v||v==='-'){el.value='';return;} const n=parseInt(v); if(!isNaN(n))el.value=n.toLocaleString(); }
    function selInput(el){ el.select(); }
    function parseVal(v){ if(!v)return 0; return parseInt(v.replace(/[^0-9-]/g,''))||0; }
    function genId(){ return Date.now()+Math.random().toString(36).substr(2,9); }

    function curData(){
        if(!data.months[data.currentMonth])data.months[data.currentMonth]=emptyMonth();
        if(!data.months[data.currentMonth].savings)data.months[data.currentMonth].savings=[];
        return data.months[data.currentMonth];
    }

    function setPerson(type,person,btn){
        selPerson[type]=person;
        btn.closest('.pselector').querySelectorAll('.pbtn').forEach(b=>b.className='pbtn');
        btn.classList.add(person==='husband'?'ah':person==='wife'?'aw':'aj');
    }

    function handleSel(type,val){
        const inp=document.getElementById(IDS[type].name);
        if(val==='기타'){ inp.classList.add('show'); inp.focus(); customOn[type]=true; }
        else { inp.classList.remove('show'); inp.value=''; customOn[type]=false; }
    }

    function enterAdd(e,type){ if(e.key==='Enter')addItem(type); }
    function enterAllow(e,who){ if(e.key==='Enter')setAllow(who); }

    function addItem(type){
        const ids=IDS[type];
        const selEl=document.getElementById(ids.sel); const nameEl=document.getElementById(ids.name); const amtEl=document.getElementById(ids.amt);
        const name=customOn[type]?nameEl.value.trim():selEl.value;
        const amount=parseVal(amtEl.value);
        if(!name||isNaN(amount)||amount<=0){ alert('항목과 금액을 올바르게 입력해주세요.'); return; }
        curData()[type].push({id:genId(),name,amount,person:selPerson[type]});
        selEl.value=''; nameEl.value=''; amtEl.value='';
        customOn[type]=false; nameEl.classList.remove('show');
        saveData(); renderAll();
    }

    function removeItem(type,id){ const cd=curData(); cd[type]=cd[type].filter(i=>i.id!==id); saveData(); renderAll(); }

    function editItem(type,id){
        const cd=curData(); const item=cd[type].find(i=>i.id===id); if(!item)return;
        const s=prompt(`[${item.name}] 새로운 금액을 입력해주세요.`,item.amount); if(s===null)return;
        const n=parseVal(s); if(isNaN(n)||n<=0){alert('올바른 금액을 입력해주세요.');return;}
        item.amount=n; saveData(); renderAll();
    }

    function setAllow(who){
        const inp=document.getElementById(who==='husband'?'husbandAmt':'wifeAmt');
        const n=parseVal(inp.value); if(isNaN(n)||n<0){alert('올바른 금액을 입력해주세요.');return;}
        const cd=curData(); if(who==='husband')cd.husbandAllowance=n; else cd.wifeAllowance=n;
        inp.value=''; saveData(); renderAll();
    }

    function resetAllow(who){
        if(!confirm(`${who==='husband'?'남편':'아내'} 용돈을 초기화하시겠습니까?`))return;
        const cd=curData(); if(who==='husband')cd.husbandAllowance=0; else cd.wifeAllowance=0;
        saveData(); renderAll();
    }

    function switchAllow(who){
        const tH=document.getElementById('tabH'),tW=document.getElementById('tabW');
        const cH=document.getElementById('allowH'),cW=document.getElementById('allowW');
        if(who==='husband'){ tH.className='allow-tab ah'; tW.className='allow-tab'; cH.style.display=''; cW.style.display='none'; }
        else { tW.className='allow-tab aw'; tH.className='allow-tab'; cW.style.display=''; cH.style.display='none'; }
    }

    /* ── BUDGET ── */
    function toggleBudget(){
        const el=document.getElementById('budgetSettings'); const btn=document.getElementById('budgetToggleBtn');
        if(el.style.display==='none'){
            el.style.display=''; btn.textContent='접기 ▲';
            const b=data.budgets||{};
            ['fixed','loan','allow','variable','savings'].forEach(k=>{
                const el2=document.getElementById('b'+k.charAt(0).toUpperCase()+k.slice(1));
                if(el2)el2.value=b[k]?b[k].toLocaleString():'';
            });
        } else { el.style.display='none'; btn.textContent='펼치기 ▼'; }
    }

    function saveBudgets(){
        data.budgets={
            fixed:   parseVal(document.getElementById('bFixed').value),
            loan:    parseVal(document.getElementById('bLoan').value),
            allow:   parseVal(document.getElementById('bAllow').value),
            variable:parseVal(document.getElementById('bVariable').value),
            savings: parseVal(document.getElementById('bSavings').value)
        };
        saveData(); renderAll();
        alert('예산 목표가 저장되었습니다.');
    }

    function renderBudgetBar(containerId,actual,budgetKey){
        const el=document.getElementById(containerId); if(!el)return;
        const budget=(data.budgets||{})[budgetKey]||0;
        if(budget===0){ el.innerHTML=''; return; }
        const pct=Math.min((actual/budget)*100,100);
        const color=pct<70?'#22c55e':pct<90?'#f59e0b':'#ef4444';
        const badge=pct>=100?'⚠️ 예산 초과':pct>=90?'⚠️ 예산 임박':pct>=70?'🟡 주의':'✅ 예산 내';
        el.innerHTML=`<div class="sec-budget">
            <div class="sec-budget-top">
                <span class="sec-budget-lbl" style="color:${color}">${badge}</span>
                <span style="color:var(--text-3)">${W(actual)} / ${W(budget)} (${pct.toFixed(0)}%)</span>
            </div>
            <div class="pbar"><div class="pbar-fill" style="width:${pct}%;background:${color}"></div></div>
        </div>`;
    }

    /* ── FAVORITES ── */
    function saveFavorite(type){
        const ids=IDS[type];
        const selEl=document.getElementById(ids.sel); const nameEl=document.getElementById(ids.name); const amtEl=document.getElementById(ids.amt);
        const name=customOn[type]?nameEl.value.trim():selEl.value;
        const amount=parseVal(amtEl.value); const person=selPerson[type];
        if(!name||amount<=0){alert('저장할 항목과 금액을 입력해주세요.');return;}
        if(!data.favorites)data.favorites={};
        if(!data.favorites[type])data.favorites[type]=[];
        if(data.favorites[type].some(f=>f.name===name&&f.amount===amount)){alert('이미 저장된 즐겨찾기입니다.');return;}
        if(data.favorites[type].length>=5){if(!confirm('즐겨찾기는 최대 5개입니다. 가장 오래된 항목을 삭제하고 추가할까요?'))return; data.favorites[type].shift();}
        data.favorites[type].push({name,amount,person});
        saveData(); renderFavorites(type);
        alert(`'${name}' 즐겨찾기에 저장되었습니다.`);
    }

    function useFavorite(type,idx){
        const fav=(data.favorites?.[type]||[])[idx]; if(!fav)return;
        const ids=IDS[type]; const selEl=document.getElementById(ids.sel); const nameEl=document.getElementById(ids.name);
        const option=Array.from(selEl.options).find(o=>o.value===fav.name);
        if(option){ selEl.value=fav.name; nameEl.classList.remove('show'); customOn[type]=false; }
        else { selEl.value='기타'; nameEl.classList.add('show'); nameEl.value=fav.name; customOn[type]=true; }
        document.getElementById(ids.amt).value=fav.amount.toLocaleString();
        selPerson[type]=fav.person||'joint';
        const ps=document.querySelector(`.pselector[data-section="${type}"]`);
        if(ps){ ps.querySelectorAll('.pbtn').forEach(b=>b.className='pbtn'); const pb=ps.querySelector(`[data-person="${fav.person||'joint'}"]`); if(pb)pb.classList.add(fav.person==='husband'?'ah':fav.person==='wife'?'aw':'aj'); }
    }

    function renderFavorites(type){
        const el=document.getElementById(type+'Favs'); if(!el)return;
        const favs=(data.favorites?.[type])||[];
        if(favs.length===0){el.innerHTML='';return;}
        el.innerHTML='<span class="fav-label">⭐</span>'+
            favs.map((f,i)=>`<button class="fav-chip" onclick="useFavorite('${type}',${i})">${esc(f.name)} <span>${W(f.amount)}</span></button>`).join('')+
            `<button class="fav-clear" onclick="clearFavs('${type}')">✕ 전체삭제</button>`;
    }

    function clearFavs(type){ if(!confirm('즐겨찾기를 모두 삭제할까요?'))return; if(data.favorites)data.favorites[type]=[]; saveData(); renderFavorites(type); }

    /* ── DONUT CHART ── */
    function renderDonutChart(t){
        const svg=document.getElementById('donutSvg'); const legend=document.getElementById('donutLegend');
        if(!svg||!legend)return;
        const cats=[
            {label:'고정비용',val:t.fix,  color:'#1d4ed8'},
            {label:'대출이자',val:t.loan, color:'#ea580c'},
            {label:'용돈',    val:t.allow,color:'#9333ea'},
            {label:'변동비용',val:t.vari, color:'#dc2626'},
            {label:'저축/투자',val:t.sav, color:'#d97706'},
        ].filter(c=>c.val>0);
        const total=cats.reduce((s,c)=>s+c.val,0);
        if(total===0){
            svg.innerHTML=`<circle cx="80" cy="80" r="55" fill="none" stroke="#e2e8f0" stroke-width="20"/>
                <text x="80" y="76" text-anchor="middle" font-size="10" fill="#94a3b8">지출</text>
                <text x="80" y="90" text-anchor="middle" font-size="10" fill="#94a3b8">없음</text>`;
            legend.innerHTML='<span style="font-size:12px;color:var(--text-3)">지출을 입력하면 분석 차트가 표시됩니다</span>';
            return;
        }
        const cx=80,cy=80,r=55,sw=20,circ=2*Math.PI*r;
        let acc=0,svgH='',legH='';
        cats.forEach(cat=>{
            const frac=cat.val/total; const dash=frac*circ; const gap=circ-dash;
            const rot=acc*360-90;
            svgH+=`<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${cat.color}" stroke-width="${sw}" stroke-dasharray="${dash.toFixed(2)} ${gap.toFixed(2)}" transform="rotate(${rot.toFixed(2)} ${cx} ${cy})"/>`;
            acc+=frac;
            const pct=(frac*100).toFixed(1);
            legH+=`<div class="legend-row"><span class="legend-dot" style="background:${cat.color}"></span><span class="legend-lbl">${cat.label}</span><span class="legend-pct">${pct}%</span><span class="legend-val">${W(cat.val)}</span></div>`;
        });
        svgH+=`<text x="${cx}" y="${cy-5}" text-anchor="middle" font-size="9" fill="#94a3b8">총지출</text>
               <text x="${cx}" y="${cy+9}" text-anchor="middle" font-size="10" fill="#0f172a" font-weight="bold">${W(total)}</text>`;
        svg.innerHTML=svgH; legend.innerHTML=legH;
    }

    /* ── CALCULATIONS ── */
    function calcTotals(d){
        const inc=(d.income||[]).reduce((s,i)=>s+i.amount,0);
        const fix=(d.fixed||[]).reduce((s,i)=>s+i.amount,0);
        const loan=(d.loan||[]).reduce((s,i)=>s+i.amount,0);
        const vari=(d.variable||[]).reduce((s,i)=>s+i.amount,0);
        const allow=(d.husbandAllowance||0)+(d.wifeAllowance||0);
        const sav=(d.savings||[]).reduce((s,i)=>s+i.amount,0);
        const exp=fix+loan+vari+allow+sav;
        return {inc,fix,loan,vari,allow,sav,exp,bal:inc-exp,rate:inc>0?(sav/inc)*100:0};
    }

    function calcPersonTotals(d,who){
        const income=(d.income||[]).filter(i=>(i.person||'joint')===who).reduce((s,i)=>s+i.amount,0);
        const exp=['fixed','loan','variable'].reduce((sum,t)=>sum+(d[t]||[]).filter(i=>(i.person||'joint')===who).reduce((s,i)=>s+i.amount,0),0);
        const sav=(d.savings||[]).filter(i=>(i.person||'joint')===who).reduce((s,i)=>s+i.amount,0);
        const allow=who==='husband'?(d.husbandAllowance||0):(d.wifeAllowance||0);
        const total=exp+allow+sav;
        return {income,exp,sav,allow,total,bal:income-total};
    }

    /* ── RENDER ── */
    function renderList(type,listId,totalId){
        const el=document.getElementById(listId); const cd=curData();
        el.innerHTML=''; let tot=0;
        cd[type].forEach(item=>{
            tot+=item.amount; const p=item.person||'joint';
            const div=document.createElement('div'); div.className='item';
            div.innerHTML=`<div class="pdot" style="background:${PDOT[p]}"></div>
                <div class="item-info"><div class="item-name">${esc(item.name)}</div><div class="item-plbl">${PLBL[p]}</div></div>
                <div class="item-amt">${W(item.amount)}</div>
                <div class="item-actions">
                    <button class="btn btn-sm btn-edit" onclick="editItem('${type}','${item.id}')">수정</button>
                    <button class="btn btn-sm btn-del" onclick="removeItem('${type}','${item.id}')">삭제</button>
                </div>`;
            el.appendChild(div);
        });
        document.getElementById(totalId).textContent=W(tot); return tot;
    }

    function renderSavings(){
        const el=document.getElementById('savingsList'); const cd=curData();
        el.innerHTML=''; let tot=0;
        cd.savings.forEach(item=>{
            tot+=item.amount; const p=item.person||'joint';
            const div=document.createElement('div'); div.className='sav-item';
            div.innerHTML=`<div class="pdot" style="background:${PDOT[p]}"></div>
                <div class="item-info"><div class="item-name">${esc(item.name)}</div><div class="item-plbl">${PLBL[p]}</div></div>
                <div class="item-amt">${W(item.amount)}</div>
                <div class="item-actions">
                    <button class="btn btn-sm btn-edit" onclick="editItem('savings','${item.id}')">수정</button>
                    <button class="btn btn-sm btn-del" onclick="removeItem('savings','${item.id}')">삭제</button>
                </div>`;
            el.appendChild(div);
        });
        document.getElementById('savingsTotal').textContent=W(tot);
    }

    function renderPersonSummary(cd){
        const h=calcPersonTotals(cd,'husband'); const w=calcPersonTotals(cd,'wife'); const t=calcTotals(cd);
        document.getElementById('hIncome').textContent=W(h.income); document.getElementById('hExpense').textContent=W(h.exp);
        document.getElementById('hAllow').textContent=W(h.allow); document.getElementById('hSavings').textContent=W(h.sav);
        const hb=document.getElementById('hBalance'); hb.textContent=W(h.bal); hb.className='pstat-val '+(h.bal>=0?'b':'e');
        document.getElementById('wIncome').textContent=W(w.income); document.getElementById('wExpense').textContent=W(w.exp);
        document.getElementById('wAllow').textContent=W(w.allow); document.getElementById('wSavings').textContent=W(w.sav);
        const wb=document.getElementById('wBalance'); wb.textContent=W(w.bal); wb.className='pstat-val '+(w.bal>=0?'b':'e');
        document.getElementById('fIncome').textContent=W(t.inc); document.getElementById('fExpense').textContent=W(t.exp);
        document.getElementById('fSavings').textContent=W(t.sav); document.getElementById('fSavRate').textContent=t.rate.toFixed(1)+'%';
        const fb=document.getElementById('fBalance'); fb.textContent=W(t.bal); fb.className='pstat-val '+(t.bal>=0?'b':'e');
    }

    function renderAll(){
        const cd=curData(); const t=calcTotals(cd);
        document.getElementById('budgetTitle').textContent=data.title; document.title=data.title;
        document.getElementById('sumIncome').textContent=W(t.inc); document.getElementById('sumExpense').textContent=W(t.exp);
        document.getElementById('sumBalance').textContent=W(t.bal);
        const srEl=document.getElementById('sumSavRate'); srEl.textContent=t.rate.toFixed(1)+'%';
        srEl.style.color=t.rate<0?'var(--expense-color)':'';
        document.getElementById('sumFixed').textContent=W(t.fix); document.getElementById('sumLoan').textContent=W(t.loan);
        document.getElementById('sumAllow').textContent=W(t.allow); document.getElementById('sumVariable').textContent=W(t.vari);

        renderList('income','incomeList','incomeTotal');
        const fixTot=renderList('fixed','fixedList','fixedTotal');
        const loanTot=renderList('loan','loanList','loanTotal');
        const varTot=renderList('variable','variableList','variableTotal');

        document.getElementById('husbandDisp').textContent=W(cd.husbandAllowance);
        document.getElementById('wifeDisp').textContent=W(cd.wifeAllowance);
        document.getElementById('allowTotal').textContent=W(cd.husbandAllowance+cd.wifeAllowance);

        renderSavings();

        // Budget progress bars
        renderBudgetBar('fixedBudgetBar',   fixTot,  'fixed');
        renderBudgetBar('loanBudgetBar',    loanTot, 'loan');
        renderBudgetBar('allowBudgetBar',   cd.husbandAllowance+cd.wifeAllowance, 'allow');
        renderBudgetBar('variableBudgetBar',varTot,  'variable');
        renderBudgetBar('savingsBudgetBar', t.sav,   'savings');

        // Savings progress
        const goalAmt=(data.budgets||{}).savings||0;
        if(goalAmt>0){
            const pct=Math.min((t.sav/goalAmt)*100,100);
            const color=pct>=100?'#22c55e':pct>=50?'#f59e0b':'#4f46e5';
            document.getElementById('progressLbl').innerHTML=`🎯 저축 목표: <span style="color:${color};font-weight:600">${W(t.sav)} / ${W(goalAmt)} (${pct.toFixed(0)}%)</span>`;
            document.getElementById('pbarFill').style.cssText=`width:${pct}%;background:${color}`;
            document.getElementById('pbarTxt').textContent=pct>=100?'🎉 저축 목표 달성!':`목표까지 ${W(goalAmt-t.sav)} 남음`;
        } else {
            document.getElementById('progressLbl').innerHTML=`💰 현재 수지: <span id="curBalance">${W(t.bal)}</span>`;
            const cl=Math.min(Math.max(t.rate,0),100);
            document.getElementById('pbarFill').style.cssText=`width:${cl}%;background:linear-gradient(90deg,#f59e0b,#fcd34d)`;
            document.getElementById('pbarTxt').textContent=t.inc>0?`저축률 ${t.rate.toFixed(1)}% (저축 ${W(t.sav)} / 수입 ${W(t.inc)})`:'수입을 입력하면 저축률이 표시됩니다';
        }

        renderPersonSummary(cd);
        renderDonutChart(t);
        ['income','fixed','loan','variable','savings'].forEach(t=>renderFavorites(t));
        updateMonthSel(); renderHistory(); renderYearSummary();
    }

    function calcYearTotals(year){
        let inc=0,fix=0,loan=0,vari=0,allow=0,sav=0;
        for(let m=1;m<=12;m++){
            const k=`${year}-${String(m).padStart(2,'0')}`;
            if(data.months[k]){
                const d=data.months[k];
                inc+=(d.income||[]).reduce((s,i)=>s+i.amount,0); fix+=(d.fixed||[]).reduce((s,i)=>s+i.amount,0);
                loan+=(d.loan||[]).reduce((s,i)=>s+i.amount,0); vari+=(d.variable||[]).reduce((s,i)=>s+i.amount,0);
                allow+=(d.husbandAllowance||0)+(d.wifeAllowance||0); sav+=(d.savings||[]).reduce((s,i)=>s+i.amount,0);
            }
        }
        const exp=fix+loan+vari+allow+sav;
        return {inc,fix,loan,vari,allow,sav,exp,bal:inc-exp,rate:inc>0?(sav/inc)*100:0};
    }

    function renderYearSummary(){
        const[yr]=data.currentMonth.split('-'); const t=calcYearTotals(parseInt(yr));
        document.getElementById('yearTitle').textContent=yr+'년';
        document.getElementById('yrIncome').textContent=W(t.inc); document.getElementById('yrExpense').textContent=W(t.exp);
        document.getElementById('yrBalance').textContent=W(t.bal); document.getElementById('yrSavRate').textContent=t.rate.toFixed(1)+'%';
        document.getElementById('yrFixed').textContent=W(t.fix); document.getElementById('yrLoan').textContent=W(t.loan);
        document.getElementById('yrAllow').textContent=W(t.allow); document.getElementById('yrVariable').textContent=W(t.vari);
        const tbody=document.getElementById('moTableBody'); tbody.innerHTML='';
        for(let m=1;m<=12;m++){
            const k=`${yr}-${String(m).padStart(2,'0')}`; const md=data.months[k]||emptyMonth(); const mt=calcTotals(md);
            const tr=document.createElement('tr');
            tr.innerHTML=`<td>${m}월</td><td>${W(mt.inc)}</td><td>${W(mt.exp)}</td>
                <td class="${mt.bal>=0?'pos':'neg'}">${W(mt.bal)}</td>
                <td class="${mt.rate>=0?'pos':'neg'}">${mt.rate.toFixed(1)}%</td>`;
            tbody.appendChild(tr);
        }
    }

    function initMonthSels(){
        const ms=document.getElementById('monthSelect');
        for(let m=1;m<=12;m++){ const o=document.createElement('option'); o.value=String(m).padStart(2,'0'); o.textContent=m+'월'; ms.appendChild(o); }
        rebuildYears();
    }

    function rebuildYears(){
        const ys=document.getElementById('yearSelect'); const curY=new Date().getFullYear();
        const dataYs=Object.keys(data.months).map(k=>parseInt(k.split('-')[0])); const selY=parseInt(data.currentMonth.split('-')[0]);
        const all=new Set([...dataYs,selY,curY]); const minY=Math.min(...all)-1; const maxY=Math.max(...all)+1;
        const prev=ys.value; ys.innerHTML='';
        for(let y=minY;y<=maxY;y++){ const o=document.createElement('option'); o.value=y; o.textContent=y+'년'; ys.appendChild(o); }
        ys.value=prev||selY;
    }

    function updateMonthSel(){ const[y,m]=data.currentMonth.split('-'); rebuildYears(); document.getElementById('yearSelect').value=y; document.getElementById('monthSelect').value=m; }
    function selectYear(){ goMonth(`${document.getElementById('yearSelect').value}-${document.getElementById('monthSelect').value}`); }
    function selectMonth(){ goMonth(`${document.getElementById('yearSelect').value}-${document.getElementById('monthSelect').value}`); }
    function changeYear(d){ const[y,m]=data.currentMonth.split('-'); goMonth(`${parseInt(y)+d}-${m}`); }
    function changeMonth(d){ const[y,m]=data.currentMonth.split('-'); let ny=parseInt(y),nm=parseInt(m)+d; if(nm>12){nm=1;ny++;}else if(nm<1){nm=12;ny--;} goMonth(`${ny}-${String(nm).padStart(2,'0')}`); }
    function goMonth(key){ data.currentMonth=key; if(!data.months[key])data.months[key]=emptyMonth(); saveData(); renderAll(); }

    function copyFromPrev(){
        const[cy,cm]=data.currentMonth.split('-'); let py=parseInt(cy),pm=parseInt(cm)-1;
        if(pm<1){pm=12;py--;} const pk=`${py}-${String(pm).padStart(2,'0')}`;
        if(!data.months[pk]){alert('이전 달 데이터가 없습니다.');return;}
        if(!confirm(`${py}년 ${pm}월 데이터를 복사하시겠습니까?\n변동비용을 제외한 데이터가 복사되며 현재 달의 데이터는 덮어쓰여집니다.`))return;
        const prev=data.months[pk]; const nd=emptyMonth();
        ['income','fixed','loan','savings'].forEach(t=>{nd[t]=(prev[t]||[]).map(i=>({...i,id:genId()}));});
        nd.husbandAllowance=prev.husbandAllowance||0; nd.wifeAllowance=prev.wifeAllowance||0;
        data.months[data.currentMonth]=nd; saveData(); renderAll(); alert('이전 달 데이터를 복사했습니다. (변동비용 제외)');
    }

    function resetMonth(){ if(!confirm('이번 달 데이터를 모두 초기화하시겠습니까?'))return; data.months[data.currentMonth]=emptyMonth(); saveData(); renderAll(); alert('이번 달 데이터를 초기화했습니다.'); }

    function renderHistory(){
        const el=document.getElementById('historyGrid'); el.innerHTML='';
        Object.keys(data.months).sort().reverse().forEach(key=>{
            const t=calcTotals(data.months[key]); const[y,m]=key.split('-');
            const div=document.createElement('div'); div.className='hist-item'+(key===data.currentMonth?' active':'');
            div.onclick=()=>goMonth(key);
            div.innerHTML=`<div class="hist-month">${y}년 ${parseInt(m)}월</div><div class="hist-bal" style="color:${t.bal>=0?'var(--income-color)':'var(--expense-color)'}">${W(t.bal)}</div>`;
            el.appendChild(div);
        });
    }

    function showTitleModal(){ document.getElementById('titleInp').value=data.title; document.getElementById('titleModal').classList.add('open'); }
    function closeTitleModal(){ document.getElementById('titleModal').classList.remove('open'); }
    function saveTitle(){ const v=document.getElementById('titleInp').value.trim(); if(!v){alert('가계부 이름을 입력해주세요.');return;} data.title=v; saveData(); renderAll(); closeTitleModal(); }

    function setSyncStatus(cls,txt){ document.getElementById('syncDot').className='sdot '+cls; document.getElementById('syncTxt').textContent=txt; }
    function showConfigModal(){ document.getElementById('cfgSheetId').value=cloud.spreadsheetId||''; document.getElementById('cfgScriptUrl').value=cloud.scriptUrl||''; document.getElementById('configModal').classList.add('open'); }
    function closeConfigModal(){ document.getElementById('configModal').classList.remove('open'); }
    function saveConfig(){ cloud.spreadsheetId=document.getElementById('cfgSheetId').value.trim(); cloud.scriptUrl=document.getElementById('cfgScriptUrl').value.trim(); localStorage.setItem('familyBudgetCloudConfig',JSON.stringify(cloud)); setSyncStatus(cloud.spreadsheetId&&cloud.scriptUrl?'connected':'disconnected',cloud.spreadsheetId&&cloud.scriptUrl?'클라우드 연결됨':'로컬 모드'); closeConfigModal(); alert('클라우드 설정이 저장되었습니다.'); }

    async function uploadToCloud(){
        if(!cloud.spreadsheetId||!cloud.scriptUrl){alert('클라우드 설정을 먼저 해주세요.');showConfigModal();return;}
        setSyncStatus('syncing','업로드 중...');
        try{const res=await fetch(cloud.scriptUrl,{method:'POST',headers:{'Content-Type':'text/plain;charset=utf-8'},body:JSON.stringify({action:'save',spreadsheetId:cloud.spreadsheetId,data})});const r=await res.json();if(r.result==='success'){setSyncStatus('connected','클라우드 연결됨');alert('업로드 완료');}else throw new Error(r.message||'업로드 실패');}
        catch(e){setSyncStatus('disconnected','업로드 실패');alert('오류: '+e.message);}
    }

    async function downloadFromCloud(){
        if(!cloud.spreadsheetId||!cloud.scriptUrl){alert('클라우드 설정을 먼저 해주세요.');showConfigModal();return;}
        setSyncStatus('syncing','다운로드 중...');
        try{const res=await fetch(`${cloud.scriptUrl}?action=load&spreadsheetId=${encodeURIComponent(cloud.spreadsheetId)}`);const r=await res.json();if(r.result==='success'&&r.data&&Object.keys(r.data).length>0){data=r.data;saveData();renderAll();setSyncStatus('connected','클라우드 연결됨');alert('다운로드 완료');}else if(r.result==='success'){setSyncStatus('connected','클라우드 연결됨');alert('클라우드에 저장된 데이터가 없습니다.');}else throw new Error(r.message||'다운로드 실패');}
        catch(e){setSyncStatus('disconnected','다운로드 실패');alert('오류: '+e.message);}
    }

    function exportData(){ const a=document.createElement('a'); a.href=URL.createObjectURL(new Blob([JSON.stringify(data,null,2)],{type:'application/json'})); a.download=`가계부_백업_${new Date().toISOString().slice(0,10)}.json`; a.click(); URL.revokeObjectURL(a.href); }
    function importData(e){ const file=e.target.files[0];if(!file)return;const r=new FileReader();r.onload=ev=>{try{const imp=JSON.parse(ev.target.result);if(!imp.months)throw new Error('올바른 가계부 파일이 아닙니다.');if(!confirm('현재 데이터를 덮어쓰고 불러오시겠습니까?'))return;data=imp;saveData();renderAll();alert('데이터를 불러왔습니다.');}catch(err){alert('오류: '+err.message);}};r.readAsText(file);e.target.value=''; }

    document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeTitleModal();closeConfigModal();}});

    function init(){ loadData(); initMonthSels(); renderAll(); }
    init();
</script>
</body>
</html>

